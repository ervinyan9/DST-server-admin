# dst-waystone 运行时环境变量
# 复制为 .env 后填入真实值；.env 不会被纳入 git。

# Klei cluster token（必填，否则只启动管理端，不启动 DST 进程）
DST_CLUSTER_TOKEN=

# 管理端 API key，建议设置为高熵随机串
DST_ADMIN_KEY=

# 默认服务器展示名
DST_SERVER_NAME=DST Admin Server

# 默认服务器密码（留空表示无密码）
DST_SERVER_PASSWORD=

# 默认游戏模式：survival / endless / wilderness
DST_GAME_MODE=survival

# 默认最大玩家数
DST_MAX_PLAYERS=6

# 是否启用 Caves 分片
DST_ENABLE_CAVES=true

# 启动时是否跳过 SteamCMD 更新 DST server（true 跳过，false 拉取/更新）
DST_SKIP_GAME_UPDATE=true

# 启动时是否拉取 Workshop MOD（true 启动前更新一次）
DST_UPDATE_MODS_ON_START=false
