# dst-waystone 运行时环境变量
# 复制为 .env 后填入真实值；.env 不会被纳入 git。
#
# 设计原则：服务器名、密码、游戏模式、人数、Caves 启停等运行时配置全部由
# 管理端面板写入 /data，不再通过环境变量管理。这里只保留启动期必需变量。

# 管理端 API key（必填，建议高熵随机串）
DST_ADMIN_KEY=

# Klei cluster token（可选；也可在管理端的 Cluster Token 卡片中填入）
DST_CLUSTER_TOKEN=

# 启动时是否跳过 SteamCMD 更新 DST server（true 跳过，false 拉取/更新）
DST_SKIP_GAME_UPDATE=true

# 启动时是否拉取 Workshop MOD（true 启动前执行一次 -only_update_server_mods）
DST_UPDATE_MODS_ON_START=false
